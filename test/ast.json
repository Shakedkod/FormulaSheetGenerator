    {
        "type": "paragraph",
        "children": [
            {
                "type": "text",
                "raw": "אנרגיה קינטית:"
            }
        ]
    },
    {
        "type": "block_math",
        "raw": "E_k = \\frac{1}{2}mv^2"
    },
    {
        "type": "blank_line"
    },
    {
        "type": "paragraph",
        "children": [
            {
                "type": "text",
                "raw": "משפט עבודה-אנרגיה:"
            }
        ]
    },
    {
        "type": "block_math",
        "raw": "\\sum \\vec{F} \\cdot \\Delta\\vec{r} = \\Delta E_k"
    },
    {
        "type": "blank_line"
    },
    {
        "type": "paragraph",
        "children": [
            {
                "type": "text",
                "raw": "אנרגיה מכנית: "
            },
            {
                "type": "inline_math",
                "raw": "E_m = E_k + U"
            },
            {
                "type": "linebreak"
            },
            {
                "type": "text",
                "raw": "כוח שעבודתו לא תלויה במסלול נקרא "
            },
            {
                "type": "strong",
                "children": [
                    {
                        "type": "text",
                        "raw": "משמר"
                    }
                ]
            },
            {
                "type": "text",
                "raw": ". לכל כוח משמר "
            },
            {
                "type": "inline_math",
                "raw": "\\nabla \\times \\vec{F} = 0"
            },
            {
                "type": "text",
                "raw": "."
