            {
                "type": "inline_math",
                "raw": "\\vec{\\tau} = \\vec{r} \\times \\vec{F}"
            },
            {
                "type": "linebreak"
            },
            {
                "type": "text",
                "raw": "תנע זוויתי: "
            },
            {
                "type": "inline_math",
                "raw": "\\vec{J} = \\vec{r} \\times \\vec{P}"
            },
            {
                "type": "linebreak"
            },
            {
                "type": "text",
                "raw": "שימור תנע זוויתי:"
            }
        ]
    },
    {
        "type": "block_math",
        "raw": "\\sum \\vec{\\tau}_i = 0 \\implies \\vec{J} = \\text{const}"
