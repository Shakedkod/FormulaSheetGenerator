            {
                "type": "inline_math",
                "raw": "\\omega = \\dot{\\theta}"
            },
            {
                "type": "linebreak"
            },
            {
                "type": "text",
                "raw": "תאוצה צנטריפטלית:"
            }
        ]
    },
    {
        "type": "block_math",
        "raw": "a_c = \\frac{v^2}{R} = \\omega^2 R"
    },
