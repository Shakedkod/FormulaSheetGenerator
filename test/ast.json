        "style": "atx",
        "children": [
            {
                "type": "text",
                "raw": "מכניקה קלאסית - דף נוסחאות"
            }
        ]
    },
    {
        "type": "heading",
        "attrs": {
            "level": 2
        },
        "style": "atx",
        "children": [
            {
                "type": "text",
                "raw": "קינמטיקה"
            }
        ]
    },
    {
        "type": "paragraph",
        "children": [
            {
                "type": "text",
                "raw": "מהירות ותאוצה:"
            }
        ]
    },
    {
        "type": "block_math",
        "raw": "v = \\frac{dx}{dt}, \\quad a = \\frac{dv}{dt}"
    },
    {
        "type": "paragraph",
        "children": [
            {
                "type": "text",
                "raw": "תנועה באצה קבועה:"
            }
        ]
    },
    {
        "type": "block_math",
        "raw": "x = x_0 + v_0 t + \\frac{1}{2}at^2"
    },
    {
        "type": "block_math",
        "raw": "v^2 = v_0^2 + 2a(x - x_0)"
    },
    {
        "type": "blank_line"
    },
    {
        "type": "heading",
        "attrs": {
            "level": 3
        },
        "style": "atx",
        "children": [
            {
                "type": "text",
                "raw": "זריקה אופקית"
            }
        ]
    },
    {
        "type": "paragraph",
        "children": [
            {
                "type": "text",
                "raw": "מרחק נפילה:"
            }
        ]
    },
    {
        "type": "block_math",
        "raw": "x(t_1) = x_0 + \\frac{v_0^2 \\sin 2\\theta}{g}"
    },
    {
        "type": "blank_line"
    },
    {
        "type": "heading",
        "attrs": {
            "level": 2
        },
        "style": "atx",
        "children": [
            {
                "type": "text",
                "raw": "דינמיקה"
            }
        ]
    },
    {
        "type": "paragraph",
        "children": [
            {
                "type": "text",
                "raw": "חוקי ניוטון:"
            }
        ]
    },
    {
        "type": "list",
        "children": [
            {
                "type": "list_item",
                "children": [
                    {
                        "type": "block_text",
                        "children": [
                            {
                                "type": "inline_math",
                                "raw": "\\sum \\vec{F}_i = 0"
                            },
                            {
                                "type": "text",
                                "raw": " — הגוף יתמיד בתנועתו"
                            }
                        ]
                    }
                ]
            },
            {
                "type": "list_item",
                "children": [
                    {
                        "type": "block_text",
                        "children": [
                            {
                                "type": "inline_math",
                                "raw": "\\sum \\vec{F}_i = \\frac{d\\vec{P}}{dt}"
                            },
                            {
                                "type": "text",
                                "raw": " — חוק שני"
                            }
                        ]
                    }
                ]
            },
            {
                "type": "list_item",
                "children": [
                    {
                        "type": "block_text",
                        "children": [
                            {
                                "type": "inline_math",
                                "raw": "\\vec{F}_{1,2} = -\\vec{F}_{2,1}"
                            },
                            {
                                "type": "text",
                                "raw": " — חוק שלישי"
                            }
                        ]
                    }
                ]
            }
        ],
        "tight": true,
        "bullet": "-",
        "attrs": {
            "depth": 0,
            "ordered": false
        }
    },
    {
        "type": "paragraph",
        "children": [
            {
                "type": "text",
                "raw": "כוח חיכוך:"
            }
        ]
    },
    {
        "type": "block_math",
        "raw": "|\\vec{F}_{max}| = \\mu_s \\cdot N, \\quad |\\vec{F}_\\mu| = \\mu_k \\cdot N"
    },
    {
        "type": "blank_line"
    },
    {
        "type": "heading",
        "attrs": {
            "level": 2
        },
        "style": "atx",
        "children": [
            {
                "type": "text",
                "raw": "וקטורים"
            }
        ]
    },
    {
        "type": "paragraph",
        "children": [
            {
                "type": "text",
                "raw": "גודל וקטור:"
            }
        ]
    },
    {
        "type": "block_math",
        "raw": "|\\vec{A}| = \\sqrt{A_x^2 + A_y^2 + A_z^2}"
    },
    {
        "type": "blank_line"
    },
    {
        "type": "paragraph",
        "children": [
            {
                "type": "text",
                "raw": "מכפלה סקלרית:"
            }
        ]
    },
    {
        "type": "block_math",
        "raw": "\\vec{A} \\cdot \\vec{B} = |\\vec{A}||\\vec{B}|\\cos\\theta"
    },
    {
        "type": "blank_line"
    },
    {
        "type": "paragraph",
        "children": [
            {
                "type": "text",
                "raw": "מכפלה וקטורית:"
            }
        ]
    },
    {
        "type": "block_math",
        "raw": "\\vec{A} \\times \\vec{B} = |\\vec{A}||\\vec{B}|\\sin\\theta \\cdot \\hat{n}"
    },
    {
        "type": "blank_line"
    },
    {
        "type": "heading",
        "attrs": {
            "level": 2
        },
        "style": "atx",
        "children": [
            {
                "type": "text",
                "raw": "עבודה ואנרגיה"
